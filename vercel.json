{
  "version": 2,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/auth/:path*", "destination": "/api/index.js" },
    { "source": "/components:path*", "destination": "/api/index.js" },
    { "source": "/orders:path*", "destination": "/api/index.js" },
    { "source": "/teams:path*", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}

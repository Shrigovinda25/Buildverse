{
  "version": 2,
  "rewrites": [
    { "source": "/api/test", "destination": "/api/test.js" },
    { "source": "/api/(.*)", "destination": "/api/server.js" },
    { "source": "/auth/(.*)", "destination": "/api/server.js" },
    { "source": "/components(.*)", "destination": "/api/server.js" },
    { "source": "/orders(.*)", "destination": "/api/server.js" },
    { "source": "/teams(.*)", "destination": "/api/server.js" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
